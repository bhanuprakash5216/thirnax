<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
  <title>Elena Morgan | Visionary Creative Portfolio</title>
  <style>
    /* ========== GLOBAL RESET & CSS VARIABLES (Dynamic Light/Dark) ========== */
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
      transition: background-color 0.2s ease, color 0.2s ease, border-color 0.2s ease, box-shadow 0.2s ease;
    }

    /* Light theme (default) */
    :root {
      --bg-body: #f8fafc;
      --bg-surface: #ffffff;
      --bg-card: #ffffff;
      --text-primary: #0f172a;
      --text-secondary: #334155;
      --text-muted: #64748b;
      --accent-primary: #7c3aed;
      --accent-glow: rgba(124, 58, 237, 0.2);
      --accent-hover: #6d28d9;
      --border-light: #e2e8f0;
      --shadow-sm: 0 10px 25px -5px rgba(0, 0, 0, 0.05), 0 8px 10px -6px rgba(0, 0, 0, 0.02);
      --shadow-md: 0 20px 25px -12px rgba(0, 0, 0, 0.08);
      --gradient-1: linear-gradient(135deg, #ede9fe 0%, #f3e8ff 100%);
      --code-bg: #f1f5f9;
      --toggle-bg: #e2e8f0;
      --toggle-knob: #ffffff;
    }

    /* Dark theme */
    [data-theme="dark"] {
      --bg-body: #020617;
      --bg-surface: #0f172a;
      --bg-card: #1e293b;
      --text-primary: #f1f5f9;
      --text-secondary: #cbd5e1;
      --text-muted: #94a3b8;
      --accent-primary: #a78bfa;
      --accent-glow: rgba(167, 139, 250, 0.25);
      --accent-hover: #c4b5fd;
      --border-light: #334155;
      --shadow-sm: 0 10px 25px -5px rgba(0, 0, 0, 0.3);
      --shadow-md: 0 20px 25px -12px rgba(0, 0, 0, 0.4);
      --gradient-1: linear-gradient(135deg, #0f172a 0%, #1e1b4b 100%);
      --code-bg: #0f172a;
      --toggle-bg: #334155;
      --toggle-knob: #a78bfa;
    }

    body {
      background: var(--bg-body);
      color: var(--text-primary);
      font-family: 'Inter', system-ui, -apple-system, 'Segoe UI', Roboto, Helvetica, sans-serif;
      line-height: 1.5;
      scroll-behavior: smooth;
    }

    /* ========== TYPOGRAPHY & UTILITIES ========== */
    .container {
      max-width: 1280px;
      margin: 0 auto;
      padding: 0 1.5rem;
    }

    /* modern glass morphism card effect */
    .card-glass {
      background: var(--bg-card);
      border-radius: 2rem;
      box-shadow: var(--shadow-sm);
      border: 1px solid var(--border-light);
      backdrop-filter: blur(0px);
      transition: transform 0.2s ease, box-shadow 0.2s ease;
    }

    .card-glass:hover {
      transform: translateY(-4px);
      box-shadow: var(--shadow-md);
    }

    /* ========== HEADER & THEME TOGGLE (Flexbox) ========== */
    .site-header {
      padding: 1.5rem 0;
      border-bottom: 1px solid var(--border-light);
      background: var(--bg-surface);
      position: sticky;
      top: 0;
      z-index: 100;
      backdrop-filter: blur(8px);
      background: rgba(var(--bg-surface-rgb), 0.8);
    }

    .header-flex {
      display: flex;
      justify-content: space-between;
      align-items: center;
      flex-wrap: wrap;
      gap: 1rem;
    }

    .logo h1 {
      font-size: 1.8rem;
      font-weight: 800;
      letter-spacing: -0.02em;
      background: linear-gradient(to right, var(--accent-primary), #c084fc);
      background-clip: text;
      -webkit-background-clip: text;
      color: transparent;
    }

    .logo p {
      font-size: 0.85rem;
      color: var(--text-muted);
      font-weight: 500;
    }

    /* Dark mode toggle switch (custom) */
    .theme-switch {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      background: var(--toggle-bg);
      padding: 0.4rem 0.8rem;
      border-radius: 3rem;
      cursor: pointer;
      border: 1px solid var(--border-light);
    }

    .theme-switch span {
      font-size: 0.9rem;
      font-weight: 500;
      color: var(--text-secondary);
    }

    .toggle-track {
      width: 48px;
      height: 24px;
      background: var(--bg-card);
      border-radius: 40px;
      display: flex;
      align-items: center;
      padding: 2px;
      transition: 0.2s;
      border: 1px solid var(--border-light);
    }

    .toggle-knob {
      width: 20px;
      height: 20px;
      background: var(--toggle-knob);
      border-radius: 50%;
      transition: transform 0.25s cubic-bezier(0.2, 0.9, 0.4, 1.1);
      transform: translateX(0);
    }

    [data-theme="dark"] .toggle-knob {
      transform: translateX(24px);
      background: #facc15;
    }

    /* ========== HERO SECTION (GRID + FLEX) ========== */
    .hero {
      padding: 4rem 0 3rem;
    }

    .hero-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 3rem;
      align-items: center;
    }

    .hero-content {
      display: flex;
      flex-direction: column;
      gap: 1.2rem;
    }

    .badge {
      background: var(--accent-glow);
      color: var(--accent-primary);
      padding: 0.3rem 1rem;
      border-radius: 40px;
      font-size: 0.85rem;
      font-weight: 600;
      width: fit-content;
      border: 1px solid var(--border-light);
    }

    .hero-content h2 {
      font-size: clamp(2.2rem, 5vw, 3.8rem);
      font-weight: 800;
      line-height: 1.2;
      letter-spacing: -0.02em;
    }

    .hero-highlight {
      color: var(--accent-primary);
      border-bottom: 3px solid var(--accent-primary);
      display: inline-block;
    }

    .hero-content p {
      color: var(--text-secondary);
      font-size: 1.2rem;
      max-width: 90%;
    }

    .btn-group {
      display: flex;
      flex-wrap: wrap;
      gap: 1rem;
      margin-top: 1rem;
    }

    .btn-primary {
      background: var(--accent-primary);
      color: white;
      border: none;
      padding: 0.8rem 1.8rem;
      border-radius: 2.5rem;
      font-weight: 600;
      cursor: pointer;
      transition: 0.2s;
      box-shadow: 0 4px 12px var(--accent-glow);
    }

    .btn-primary:hover {
      background: var(--accent-hover);
      transform: scale(1.02);
    }

    .btn-outline {
      background: transparent;
      border: 1.5px solid var(--border-light);
      color: var(--text-primary);
      padding: 0.8rem 1.8rem;
      border-radius: 2.5rem;
      font-weight: 600;
      cursor: pointer;
      transition: 0.2s;
    }

    .btn-outline:hover {
      border-color: var(--accent-primary);
      color: var(--accent-primary);
    }

    .hero-visual {
      background: var(--gradient-1);
      border-radius: 2.5rem;
      aspect-ratio: 1 / 1;
      display: flex;
      align-items: center;
      justify-content: center;
      box-shadow: var(--shadow-md);
      border: 1px solid var(--border-light);
    }

    .hero-visual span {
      font-size: 7rem;
      font-weight: 800;
      opacity: 0.8;
    }

    /* ========== SKILLS SECTION (FLEXBOX GRID MIX) ========== */
    .skills {
      padding: 4rem 0;
    }

    .section-title {
      font-size: 2rem;
      font-weight: 700;
      margin-bottom: 2rem;
      position: relative;
      display: inline-block;
    }

    .section-title:after {
      content: '';
      position: absolute;
      bottom: -10px;
      left: 0;
      width: 60px;
      height: 4px;
      background: var(--accent-primary);
      border-radius: 4px;
    }

    .skills-flex {
      display: flex;
      flex-wrap: wrap;
      gap: 1rem;
      margin-top: 2rem;
    }

    .skill-tag {
      background: var(--bg-card);
      border: 1px solid var(--border-light);
      padding: 0.7rem 1.5rem;
      border-radius: 60px;
      font-weight: 500;
      color: var(--text-secondary);
      transition: all 0.2s;
    }

    .skill-tag:hover {
      border-color: var(--accent-primary);
      color: var(--accent-primary);
      transform: translateY(-2px);
      box-shadow: var(--shadow-sm);
    }

    /* ========== PROJECTS SHOWCASE (CSS GRID COMPLEX) ========== */
    .projects {
      padding: 4rem 0;
    }

    .projects-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
      gap: 2rem;
      margin-top: 2rem;
    }

    .project-card {
      background: var(--bg-card);
      border-radius: 1.8rem;
      overflow: hidden;
      border: 1px solid var(--border-light);
      transition: all 0.25s;
      display: flex;
      flex-direction: column;
    }

    .project-img {
      height: 220px;
      background: var(--gradient-1);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 3rem;
      font-weight: bold;
      color: var(--accent-primary);
    }

    .project-info {
      padding: 1.8rem;
      display: flex;
      flex-direction: column;
      gap: 0.8rem;
      flex: 1;
    }

    .project-info h3 {
      font-size: 1.5rem;
      font-weight: 700;
    }

    .project-cats {
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem;
    }

    .cat {
      font-size: 0.7rem;
      background: var(--accent-glow);
      padding: 0.2rem 0.8rem;
      border-radius: 30px;
      color: var(--accent-primary);
      font-weight: 600;
    }

    .project-link {
      margin-top: 1rem;
      font-weight: 600;
      color: var(--accent-primary);
      text-decoration: none;
      display: inline-flex;
      align-items: center;
      gap: 0.3rem;
    }

    .project-link:hover {
      text-decoration: underline;
    }

    /* ========== TESTIMONIAL SECTION (FLEX + GRID HARMONY) ========== */
    .testimonials {
      padding: 4rem 0;
      background: var(--bg-surface);
      border-radius: 3rem;
      margin: 2rem 0;
    }

    .testimonial-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: 2rem;
      margin-top: 2rem;
    }

    .testi-card {
      background: var(--bg-card);
      padding: 2rem;
      border-radius: 2rem;
      border: 1px solid var(--border-light);
      display: flex;
      flex-direction: column;
      gap: 1rem;
    }

    .quote {
      font-style: italic;
      color: var(--text-secondary);
      font-size: 1rem;
      line-height: 1.5;
    }

    .client {
      font-weight: 700;
      margin-top: 0.5rem;
      color: var(--accent-primary);
    }

    /* ========== CONTACT + FOOTER (GRID & FLEX MIX) ========== */
    .contact-section {
      padding: 4rem 0 2rem;
    }

    .contact-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 3rem;
      background: var(--bg-card);
      border-radius: 2rem;
      padding: 2rem;
      border: 1px solid var(--border-light);
    }

    .contact-info {
      display: flex;
      flex-direction: column;
      gap: 1rem;
    }

    .contact-info h3 {
      font-size: 1.8rem;
    }

    .social-links {
      display: flex;
      gap: 1.2rem;
      margin-top: 1rem;
    }

    .social-icon {
      background: var(--bg-body);
      padding: 0.6rem 1rem;
      border-radius: 3rem;
      text-decoration: none;
      color: var(--text-secondary);
      font-weight: 500;
      transition: 0.2s;
      border: 1px solid var(--border-light);
    }

    .social-icon:hover {
      background: var(--accent-primary);
      color: white;
    }

    .contact-form {
      display: flex;
      flex-direction: column;
      gap: 1.2rem;
    }

    .contact-form input, .contact-form textarea {
      background: var(--bg-body);
      border: 1px solid var(--border-light);
      padding: 1rem;
      border-radius: 1.5rem;
      color: var(--text-primary);
      font-family: inherit;
      resize: vertical;
    }

    .contact-form input:focus, .contact-form textarea:focus {
      outline: none;
      border-color: var(--accent-primary);
      box-shadow: 0 0 0 2px var(--accent-glow);
    }

    footer {
      text-align: center;
      padding: 2rem 0;
      border-top: 1px solid var(--border-light);
      margin-top: 2rem;
      color: var(--text-muted);
    }

    /* ========== RESPONSIVE MEDIA QUERIES (MOBILE-FIRST) ========== */
    /* Tablet and desktop overrides */
    @media (max-width: 1024px) {
      .hero-grid {
        gap: 2rem;
      }
      .contact-grid {
        grid-template-columns: 1fr;
      }
    }

    @media (max-width: 768px) {
      .hero-grid {
        grid-template-columns: 1fr;
        text-align: center;
      }
      .hero-content p {
        max-width: 100%;
      }
      .btn-group {
        justify-content: center;
      }
      .badge {
        margin: 0 auto;
      }
      .section-title:after {
        left: 50%;
        transform: translateX(-50%);
      }
      .section-title {
        text-align: center;
        display: block;
      }
      .skills-flex {
        justify-content: center;
      }
      .projects-grid {
        grid-template-columns: 1fr;
      }
      .testimonial-grid {
        grid-template-columns: 1fr;
      }
      .contact-grid {
        padding: 1.5rem;
      }
    }

    @media (max-width: 480px) {
      .container {
        padding: 0 1.2rem;
      }
      .hero-content h2 {
        font-size: 2rem;
      }
      .project-img {
        height: 160px;
      }
      .header-flex {
        flex-direction: column;
      }
    }

    /* additional micro-interactions */
    a, button {
      cursor: pointer;
    }

    ::selection {
      background: var(--accent-primary);
      color: white;
    }
  </style>
</head>
<body>

<header class="site-header">
  <div class="container header-flex">
    <div class="logo">
      <h1>ELENA<span style="color:var(--accent-primary);">.</span>MORGAN</h1>
      <p>creative direction & interactive design</p>
    </div>
    <div class="theme-switch" id="themeToggle" aria-label="Light/Dark mode switch">
      <span>🌞</span>
      <div class="toggle-track">
        <div class="toggle-knob"></div>
      </div>
      <span>🌙</span>
    </div>
  </div>
</header>

<main>
  <!-- Hero Section: CSS Grid + Flexbox alignment -->
  <section class="hero">
    <div class="container hero-grid">
      <div class="hero-content">
        <div class="badge">✦ DIGITAL ARTISAN ✦</div>
        <h2>Crafting immersive <span class="hero-highlight">digital experiences</span> with code & soul.</h2>
        <p>I blend advanced CSS architectures, fluid interactions, and modern design systems to bring visionary concepts to life.</p>
        <div class="btn-group">
          <button class="btn-primary" id="discoverBtn">View work →</button>
          <button class="btn-outline" id="contactBtn">Let's connect</button>
        </div>
      </div>
      <div class="hero-visual">
        <span>✨</span>
      </div>
    </div>
  </section>

  <!-- Skills: Flexbox master -->
  <section class="skills">
    <div class="container">
      <h2 class="section-title">· Core competencies</h2>
      <div class="skills-flex">
        <span class="skill-tag">CSS Grid Architecture</span>
        <span class="skill-tag">Flexbox Alignment</span>
        <span class="skill-tag">Responsive Design Systems</span>
        <span class="skill-tag">Dark / Light mode theming</span>
        <span class="skill-tag">React & Vue</span>
        <span class="skill-tag">Motion Design</span>
        <span class="skill-tag">Web Accessibility</span>
        <span class="skill-tag">UI Animation</span>
      </div>
    </div>
  </section>

  <!-- Project Showcase: Advanced Grid Layouts -->
  <section class="projects">
    <div class="container">
      <h2 class="section-title">· Featured creations</h2>
      <div class="projects-grid">
        <div class="project-card">
          <div class="project-img">🌌</div>
          <div class="project-info">
            <h3>Nebula Grid</h3>
            <div class="project-cats"><span class="cat">CSS GRID</span><span class="cat">RESPONSIVE</span></div>
            <p>Complex 2D magazine layout with auto-placement, overlapping zones, and dynamic theming.</p>
            <a href="#" class="project-link">Explore case study →</a>
          </div>
        </div>
        <div class="project-card">
          <div class="project-img">🎨</div>
          <div class="project-info">
            <h3>Chromatic Flex</h3>
            <div class="project-cats"><span class="cat">FLEXBOX</span><span class="cat">ADAPTIVE</span></div>
            <p>Fluid component library with smart alignment, wrapping behavior and fully accessible API.</p>
            <a href="#" class="project-link">Discover more →</a>
          </div>
        </div>
        <div class="project-card">
          <div class="project-img">⚡</div>
          <div class="project-info">
            <h3>Luminous Agency</h3>
            <div class="project-cats"><span class="cat">UI/UX</span><span class="cat">DARK MODE</span></div>
            <p>Custom CSS variables + prefers-color-scheme override, global theme toggle with smooth transition.</p>
            <a href="#" class="project-link">Live demo →</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Testimonials Grid -->
  <div class="container">
    <section class="testimonials">
      <h2 class="section-title">· Kind words</h2>
      <div class="testimonial-grid">
        <div class="testi-card">
          <div class="quote">“Elena's mastery over modern CSS is unmatched. The portfolio she built responds like a living organism on every device.”</div>
          <div class="client">— Marcus Chen, Design Lead</div>
        </div>
        <div class="testi-card">
          <div class="quote">“Her approach to light/dark mode and grid architectures saved us months of refactoring. A visionary front-end architect.”</div>
          <div class="client">— Sofia Rivera, CTO @ Lattice</div>
        </div>
        <div class="testi-card">
          <div class="quote">“Finally, a portfolio that feels futuristic yet semantic. The attention to responsive detail blew our entire team away.”</div>
          <div class="client">— David Okafor, Product Manager</div>
        </div>
      </div>
    </section>
  </div>

  <!-- Contact + Footer hybrid grid -->
  <section class="contact-section">
    <div class="container contact-grid">
      <div class="contact-info">
        <h3>Let's create ✦</h3>
        <p>Have a bold vision? I'm currently available for select collaborations and immersive digital projects.</p>
        <div class="social-links">
          <a href="#" class="social-icon">Dribbble</a>
          <a href="#" class="social-icon">GitHub</a>
          <a href="#" class="social-icon">LinkedIn</a>
          <a href="#" class="social-icon">Instagram</a>
        </div>
      </div>
      <form class="contact-form" id="dummyContactForm">
        <input type="text" placeholder="Full name" aria-label="Your name">
        <input type="email" placeholder="Email address" aria-label="Email">
        <textarea rows="3" placeholder="Tell me about your project..."></textarea>
        <button type="button" class="btn-primary" id="formSubmitBtn" style="width:fit-content">Send message →</button>
        <p id="formFeedback" style="font-size:0.8rem; margin-top:0.2rem; color:var(--accent-primary)"></p>
      </form>
    </div>
    <footer>
      <div class="container">
        <p>© 2026 Elena Morgan — Advanced CSS3 & Responsive Architecture. All interactions handcrafted.</p>
      </div>
    </footer>
  </section>
</main>

<script>
  (function(){
    // ========== DARK/LIGHT MODE TOGGLE (CSS Variables + data-theme) ==========
    const themeToggle = document.getElementById('themeToggle');
    const rootElement = document.documentElement;
    
    // Retrieve saved preference or system preference fallback
    const storedTheme = localStorage.getItem('portfolio-theme');
    if (storedTheme === 'dark') {
      rootElement.setAttribute('data-theme', 'dark');
    } else if (storedTheme === 'light') {
      rootElement.setAttribute('data-theme', 'light');
    } else {
      // optional: use prefers-color-scheme? but we respect manual first load: default light
      const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
      if (prefersDark) {
        rootElement.setAttribute('data-theme', 'dark');
      } else {
        rootElement.setAttribute('data-theme', 'light');
      }
    }
    
    function toggleTheme() {
      const currentTheme = rootElement.getAttribute('data-theme');
      if (currentTheme === 'dark') {
        rootElement.setAttribute('data-theme', 'light');
        localStorage.setItem('portfolio-theme', 'light');
      } else {
        rootElement.setAttribute('data-theme', 'dark');
        localStorage.setItem('portfolio-theme', 'dark');
      }
    }
    
    if (themeToggle) {
      themeToggle.addEventListener('click', toggleTheme);
    }
    
    // Small interactive feedback (mimic contact form)
    const submitBtn = document.getElementById('formSubmitBtn');
    const feedbackSpan = document.getElementById('formFeedback');
    if (submitBtn) {
      submitBtn.addEventListener('click', function(e) {
        feedbackSpan.textContent = '✨ Thanks! A creative conversation will follow shortly.';
        setTimeout(() => {
          feedbackSpan.textContent = '';
        }, 3000);
        // clear placeholder values? optional: but just demo
        const form = document.getElementById('dummyContactForm');
        if(form) form.reset();
      });
    }
    
    // Buttons interaction - smooth scroll to projects or contact
    const discoverBtn = document.getElementById('discoverBtn');
    const contactBtn = document.getElementById('contactBtn');
    
    if (discoverBtn) {
      discoverBtn.addEventListener('click', () => {
        const projectsSection = document.querySelector('.projects');
        if (projectsSection) {
          projectsSection.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }
      });
    }
    
    if (contactBtn) {
      contactBtn.addEventListener('click', () => {
        const contactSection = document.querySelector('.contact-section');
        if (contactSection) {
          contactSection.scrollIntoView({ behavior: 'smooth', block: 'center' });
        }
      });
    }
    
    // small animation for hero icon
    const heroIcon = document.querySelector('.hero-visual span');
    if (heroIcon) {
      setInterval(() => {
        heroIcon.style.transform = 'scale(1.08)';
        setTimeout(() => {
          heroIcon.style.transform = 'scale(1)';
        }, 400);
      }, 3000);
    }
  })();
</script>
</body>
</html>